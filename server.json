{
  "server": {
    "name": "Bike File Runner",
    "version": "1.0.0",
    "port": 8080,
    "host": "0.0.0.0",
    "environment": "production",
    "max_connections": 100,
    "timeout_seconds": 30,
    "max_file_size_mb": 50,
    "allowed_extensions": [".py", ".js", ".zip"],
    "rate_limit": {
      "enabled": true,
      "requests_per_minute": 60
    },
    "description": "Railway pe file runner system"
  }
}